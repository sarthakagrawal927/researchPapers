# Copy to .env and fill in. All values are optional for the ClickHouse-only
# runtime (API + frontend + analytics jobs). See README and DEPLOY.md.

# ClickHouse is read via clickhouse-connect with defaults host=127.0.0.1,
# port=8123, database=papers, user=default, no password. Override below if
# your CH lives elsewhere.
# CLICKHOUSE_HOST=127.0.0.1
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DB=papers

# Only needed for the legacy CLI commands that still touch Postgres
# (ingest, download-pdfs, extract-urls). Safe to leave unset otherwise.
# POSTGRES_URL=postgresql://papers:papers@localhost:5433/papers

# Optional. arXiv API works without auth. Semantic Scholar tier without a key
# is heavily rate-limited; request one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Contact email used in the User-Agent header for polite scraping. Required by
# arXiv's API policy and Semantic Scholar's terms.
CONTACT_EMAIL=sarthakagrawal927@gmail.com
